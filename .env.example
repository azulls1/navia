# Tu API key de Anthropic (https://console.anthropic.com/)
ANTHROPIC_API_KEY=sk-ant-...

# Opcional: modelo por defecto (default: claude-sonnet-4-6)
# NAVIA_MODEL=claude-sonnet-4-6

# Opcional: motor por defecto (chrome | firefox | chromium)  default: chromium
# NAVIA_BROWSER=chromium

# Opcional pero recomendado: cifra los perfiles de sesión (navia login) con AES-256-GCM.
# NAVIA_SECRET=una-frase-larga-y-secreta
