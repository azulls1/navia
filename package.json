{
  "name": "navia-ai",
  "version": "0.24.6",
  "description": "Agente de navegador autónomo con IA (Claude). Abre Chrome o Firefox reales, lee la página y la opera con una sola instrucción en lenguaje natural. Incluye truco CDP anti-Cloudflare.",
  "type": "module",
  "bin": {
    "navia": "dist/cli.js"
  },
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "examples/eval",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "browser-automation",
    "ai-agent",
    "claude",
    "anthropic",
    "playwright",
    "web-automation",
    "cloudflare",
    "cdp",
    "chrome",
    "firefox",
    "llm",
    "agent"
  ],
  "author": "azulls1",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/azulls1/navia.git"
  },
  "bugs": {
    "url": "https://github.com/azulls1/navia/issues"
  },
  "homepage": "https://github.com/azulls1/navia#readme",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.65.0",
    "@modelcontextprotocol/sdk": "^1.18.0",
    "commander": "^14.0.0",
    "dotenv": "^17.0.0",
    "picocolors": "^1.1.1",
    "playwright": "^1.56.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.0",
    "vitest": "^3.0.0"
  }
}
